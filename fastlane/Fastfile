default_platform(:ios)

platform :ios do
  desc "Build and upload a release train to TestFlight"
  lane :beta do |options|
    channel = options[:channel]
    UI.user_error!("Pass channel:nightly or channel:weekly") unless %w[nightly weekly].include?(channel)

    require "json"
    api_key_data = JSON.parse(File.read(ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH")))
    api_key = app_store_connect_api_key(
      key_id: api_key_data.fetch("key_id"),
      issuer_id: api_key_data.fetch("issuer_id"),
      key_content: api_key_data.fetch("key"),
      in_house: api_key_data.fetch("in_house", false)
    )
    app_identifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)

    match(
      type: "appstore",
      api_key: api_key,
      readonly: ENV["CI"].to_s.casecmp("true").zero?
    )

    if ENV["CI"].to_s.casecmp("true").zero?
      mapping = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING] || {}
      {
        "Visual Timer" => "Dan.Visual-Timer",
        "TurnTimerWidgets" => "Dan.Visual-Timer.TurnTimerWidgets",
        "Visual Timer Watch" => "Dan.Visual-Timer-Watch",
        "Visual Timer Watch Watch App" => "Dan.Visual-Timer-Watch.watchkitapp"
      }.each do |target, bundle_id|
        profile = mapping[bundle_id]
        next if profile.nil?

        update_code_signing_settings(
          path: "Visual Timer.xcodeproj",
          use_automatic_signing: false,
          targets: [target],
          team_id: "8AXNA5B37R",
          code_sign_identity: "Apple Distribution",
          profile_name: profile
        )
      end
    end

    latest_build_number = latest_testflight_build_number(
      app_identifier: app_identifier,
      api_key: api_key,
      initial_build_number: 0
    )

    increment_build_number(
      build_number: latest_build_number + 1,
      xcodeproj: "Visual Timer.xcodeproj"
    )

    build_app(
      project: "Visual Timer.xcodeproj",
      scheme: "Visual Timer",
      export_method: "app-store",
      clean: true,
      output_directory: "fastlane/builds/#{channel}",
      output_name: "TurnTimer-#{channel}.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      groups: [channel],
      skip_waiting_for_build_processing: true
    )
  end
end
